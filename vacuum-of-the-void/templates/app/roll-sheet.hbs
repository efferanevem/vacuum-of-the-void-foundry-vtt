<form class="votv roll-sheet" autocomplete="off" data-votv-roll-sheet="{{appId}}" data-base-mod="{{baseModifier}}" data-injury-mod="{{injuryModifier}}" data-injury-penalty="{{injuryPenalty}}">
  <header class="roll-sheet-header">
    <h3 class="roll-sheet-title">{{skillLabel}}</h3>
    <p class="roll-sheet-formula">{{formulaText}}</p>
    {{#if targetLabel}}
      <p class="roll-sheet-target">Célpont: {{targetLabel}}</p>
    {{/if}}
  </header>

  <div class="roll-sheet-row roll-sheet-row-morale">
    <label>Morálkockák (Σ {{moraleCurrent}} db)</label>
    <div class="roll-sheet-morale-wrap" data-morale-max="{{moraleCurrent}}">
      <div class="roll-sheet-morale-icons">
        <img class="roll-sheet-morale-d8" src="systems/vacuum-of-the-void/assets/moral_d8.svg" data-morale-value="1" alt="1" title="1 morál" />
        <img class="roll-sheet-morale-d8" src="systems/vacuum-of-the-void/assets/moral_d8.svg" data-morale-value="2" alt="2" title="2 morál" />
        <img class="roll-sheet-morale-d8" src="systems/vacuum-of-the-void/assets/moral_d8.svg" data-morale-value="3" alt="3" title="3 morál" />
      </div>
      <input type="hidden" name="moraleDice" value="0" />
      <button type="button" class="roll-sheet-morale-reset" data-morale-value="0" title="0 morál" aria-label="0 morál">
        <svg class="roll-sheet-morale-reset-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="10" cy="10" r="8"/><path d="M6 6l8 8M14 6l-8 8"/></svg>
      </button>
    </div>
  </div>

  <div class="roll-sheet-row roll-sheet-row-advantage">
    <label>Előnyök / Hátrányok</label>
    <div class="roll-sheet-advantage-wrap">
      <div class="roll-sheet-advantage-icons">
        <img class="roll-sheet-advantage-d6" src="systems/vacuum-of-the-void/assets/disadvantage_d6.svg" data-advantage-value="-3" alt="-3" title="-3d6 hátrány" />
        <img class="roll-sheet-advantage-d6" src="systems/vacuum-of-the-void/assets/disadvantage_d6.svg" data-advantage-value="-2" alt="-2" title="-2d6 hátrány" />
        <img class="roll-sheet-advantage-d6" src="systems/vacuum-of-the-void/assets/disadvantage_d6.svg" data-advantage-value="-1" alt="-1" title="-1d6 hátrány" />
        <img class="roll-sheet-advantage-d6 roll-sheet-advantage-d6-neutral" src="systems/vacuum-of-the-void/assets/d6.svg" data-advantage-value="0" alt="0" title="Sem előny, sem hátrány" />
        <img class="roll-sheet-advantage-d6" src="systems/vacuum-of-the-void/assets/advantage_d6.svg" data-advantage-value="1" alt="+1" title="+1d6 előny" />
        <img class="roll-sheet-advantage-d6" src="systems/vacuum-of-the-void/assets/advantage_d6.svg" data-advantage-value="2" alt="+2" title="+2d6 előny" />
        <img class="roll-sheet-advantage-d6" src="systems/vacuum-of-the-void/assets/advantage_d6.svg" data-advantage-value="3" alt="+3" title="+3d6 előny" />
      </div>
      <input type="hidden" name="advantage" value="{{advantageValue}}" />
    </div>
  </div>

  <div class="roll-sheet-row roll-sheet-row-constant">
    <label>Egyéb Bónusz:</label>
    <div class="roll-sheet-constant-wrap">
      <input type="number" name="constantBonus" class="roll-sheet-constant" value="0" min="-99" max="99" />
    </div>
  </div>

  <div class="roll-sheet-formula-preview" aria-live="polite"></div>

  {{#if advantageSourcesText}}
    <p class="roll-sheet-advantage-sources roll-sheet-advantage-sources--elony">Előnyök: {{advantageSourcesText}}</p>
  {{/if}}
  {{#if disadvantageSourcesText}}
    <p class="roll-sheet-advantage-sources roll-sheet-advantage-sources--hatrany">Hátrányok: {{disadvantageSourcesText}}</p>
  {{/if}}
  {{#if blockRollWarningMessage}}
    <p class="roll-sheet-warning roll-sheet-heavy-halfcover">{{blockRollWarningMessage}}</p>
  {{/if}}

  <footer class="roll-sheet-footer">
    <button type="button" class="roll-sheet-close">Bezárás</button>
    <button type="button" class="roll-sheet-do-roll{{#if disableRollButton}} roll-sheet-do-roll--disabled{{/if}}" {{#if disableRollButton}}disabled{{/if}}>Dobás</button>
  </footer>
</form>
