<form class="{{cssClass}} votv-targy-sheet" autocomplete="off">
  <header class="sheet-header">
    <img class="profile" src="{{item.img}}" data-edit="img" title="{{item.name}}" />
    <div class="header-fields">
      <h1 class="item-name">
        <input name="name" type="text" value="{{item.name}}" placeholder="Tárgy neve" />
      </h1>
    </div>
  </header>

  <section class="sheet-body">
    <div class="field">
      <label>Leírás</label>
      <textarea name="system.description" rows="8">{{system.description}}</textarea>
    </div>
  </section>
</form>
