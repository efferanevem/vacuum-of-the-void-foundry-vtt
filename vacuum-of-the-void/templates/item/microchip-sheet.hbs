<form class="{{cssClass}} votv-microchip-sheet" autocomplete="off">
  <header class="sheet-header">
    <img class="profile" src="{{item.img}}" data-edit="img" title="{{item.name}}" />
    <div class="header-fields">
      <h1 class="item-name">
        <input name="name" type="text" value="{{item.name}}" placeholder="Mikro-chip neve" />
      </h1>
      <div class="item-type">
        <label>Képesség típusa</label>
        <select name="system.abilityType">
          <option value="passive" {{#if (eq system.abilityType "passive")}}selected{{/if}}>Passzív</option>
          <option value="active" {{#if (eq system.abilityType "active")}}selected{{/if}}>Aktív</option>
        </select>
      </div>
    </div>
  </header>

  <section class="sheet-body">
    <div class="microchip-grid">
      <div class="field">
        <label>Vásárlás ára (cr)</label>
        <input type="number" name="system.cost" value="{{system.cost}}" min="0" />
      </div>
      <div class="field">
        <label>Lecserélés (Küzdelmi Pont)</label>
        <input type="number" name="system.replaceCost" value="{{system.replaceCost}}" min="0" />
      </div>
    </div>

    <div class="field">
      <label>Leírás / Hatás</label>
      <textarea name="system.description" rows="6">{{system.description}}</textarea>
    </div>
  </section>
</form>
