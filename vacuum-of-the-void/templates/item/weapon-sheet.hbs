<form class="{{cssClass}} votv-weapon-sheet" autocomplete="off">
  <header class="sheet-header">
    <img class="profile" src="{{item.img}}" data-edit="img" title="{{item.name}}" />
    <div class="header-fields">
      <h1 class="item-name">
        <input name="name" type="text" value="{{item.name}}" placeholder="Fegyver neve" />
      </h1>
    </div>
  </header>

  <section class="sheet-body">
    <div class="weapon-grid">
      <div class="field">
        <label>Típus</label>
        <select name="system.type">
          <option value="kinetic" {{#if (eq system.type "kinetic")}}selected{{/if}}>Kinetikus</option>
          <option value="projectile" {{#if (eq system.type "projectile")}}selected{{/if}}>Lövedékes</option>
          <option value="blade" {{#if (eq system.type "blade")}}selected{{/if}}>Pengés</option>
          <option value="explosive" {{#if (eq system.type "explosive")}}selected{{/if}}>Robbanó</option>
          <option value="other" {{#if (eq system.type "other")}}selected{{/if}}>Egyéb</option>
        </select>
      </div>
      <div class="field">
        <label>Méret</label>
        <select name="system.size">
          <option value="light" {{#if (eq system.size "light")}}selected{{/if}}>Könnyű</option>
          <option value="medium" {{#if (eq system.size "medium")}}selected{{/if}}>Közepes</option>
          <option value="heavy" {{#if (eq system.size "heavy")}}selected{{/if}}>Nehéz</option>
          <option value="thrown" {{#if (eq system.size "thrown")}}selected{{/if}}>Dobható</option>
        </select>
      </div>
      <div class="field">
        <label>Bónusz</label>
        <input type="text" name="system.bonus" value="{{system.bonus}}" placeholder="pl. +3" />
      </div>
      <div class="field">
        <label>Sebzés</label>
        <input type="text" name="system.damage" value="{{system.damage}}" placeholder="pl. 1d6+2" />
      </div>
      <div class="field">
        <label>Hatótáv</label>
        <input type="text" name="system.range" value="{{system.range}}" placeholder="pl. 27/54 m" />
      </div>
      <div class="field">
        <label>Lőszer (db)</label>
        {{#if (eq system.type "projectile")}}
          <input type="text" name="system.quantity" value="{{system.quantity}}" placeholder="pl. 6 vagy ∞" />
        {{else}}
          <input type="text" name="system.quantity" value="" readonly placeholder="-" />
        {{/if}}
      </div>
    </div>

    <div class="field">
      <label>Speciális</label>
      <textarea name="system.special">{{system.special}}</textarea>
    </div>
  </section>
</form>

