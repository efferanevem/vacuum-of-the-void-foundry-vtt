<form class="{{cssClass}} votv-kepesseg-sheet" autocomplete="off">
  <header class="sheet-header">
    <img class="profile" src="{{item.img}}" data-edit="img" />
    <div class="header-fields">
      <h1 class="item-name">
        <input name="name" type="text" value="{{item.name}}" placeholder="Képesség neve" />
      </h1>
      <div class="item-type">
        <label>Típus</label>
        <select name="system.kind">
          <option value="active" {{#if (eq system.kind "active")}}selected{{/if}}>Aktív</option>
          <option value="passive" {{#if (eq system.kind "passive")}}selected{{/if}}>Passzív</option>
          <option value="species" {{#if (eq system.kind "species")}}selected{{/if}}>Faji</option>
          <option value="background" {{#if (eq system.kind "background")}}selected{{/if}}>Háttér</option>
          <option value="module" {{#if (eq system.kind "module")}}selected{{/if}}>Modul</option>
        </select>
      </div>
    </div>
  </header>

  <section class="sheet-body">
    <div class="ability-grid">
      {{#if (or (eq system.kind "active") (eq system.kind "module"))}}
      <div class="field">
        <label>Küzdelmi Pont</label>
        <input type="number" name="system.kp" value="{{system.kp}}" min="0" />
      </div>
      {{/if}}
    </div>

    <div class="field">
      <label>Leírás</label>
      <textarea name="system.description" rows="{{descriptionRows}}">{{system.description}}</textarea>
    </div>
  </section>
</form>

