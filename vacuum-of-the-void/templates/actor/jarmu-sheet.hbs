<form class="votv jarmu-sheet karakter-sheet" autocomplete="off">
  <header class="jarmu-header">
    <div class="jarmu-header-row">
      <div class="jarmu-header-field jarmu-header-name">
        <label>Név</label>
        <input type="text" name="name" value="{{actor.name}}" data-dtype="String" />
      </div>
      {{#unless (eq actor.type "Bazis")}}
        <div class="jarmu-header-field jarmu-header-type">
          <label>Típus</label>
          <input type="text" name="system.vehicle.type" value="{{system.vehicle.type}}" data-dtype="String" />
        </div>
        <div class="jarmu-header-field jarmu-header-size">
          <label>Méret</label>
          <span class="jarmu-header-size-value">{{sizeForSelect}} ({{unitCount}} egység)</span>
        </div>
      {{/unless}}
    </div>
  </header>

  <section class="jarmu-main">
    <section class="jarmu-column jarmu-left">
      {{#unless (eq actor.type "Bazis")}}
      <section class="karakter-panel jarmu-portrait">
        <img
          class="jarmu-portrait-img"
          src="{{actor.img}}"
          data-edit="img"
          alt="{{actor.name}}"
        />
      </section>
      {{/unless}}
    </section>
    <section class="jarmu-column jarmu-right">
      <section class="karakter-panel jarmu-stats">
        {{#if (eq actor.type "Bazis")}}
          <div class="jarmu-stat-row jarmu-stat-row-duo">
            <div class="jarmu-stat-cell">
              <label>Régió</label>
              <select
                name="system.identity.assignment"
                class="jarmu-region-select"
              >
                <option value=""></option>
                <option value="Középső Rendszerek" {{#if (eq system.identity.assignment "Középső Rendszerek")}}selected{{/if}}>
                  Középső Rendszerek
                </option>
                <option value="Köztársasági Ágak" {{#if (eq system.identity.assignment "Köztársasági Ágak")}}selected{{/if}}>
                  Köztársasági Ágak
                </option>
                <option value="Peremvidék, vagy azon túl" {{#if (eq system.identity.assignment "Peremvidék, vagy azon túl")}}selected{{/if}}>
                  Peremvidék, vagy azon túl
                </option>
              </select>
            </div>
            <div class="jarmu-stat-cell">
              <label>Zóna Típus</label>
              <select
                name="system.identity.subAssignment"
                class="jarmu-region-select"
              >
                <option value=""></option>
                <option value="Polgári Zóna" {{#if (eq system.identity.subAssignment "Polgári Zóna")}}selected{{/if}}>Polgári Zóna</option>
                <option value="Ipari Zóna" {{#if (eq system.identity.subAssignment "Ipari Zóna")}}selected{{/if}}>Ipari Zóna</option>
                <option value="Bánya Zóna" {{#if (eq system.identity.subAssignment "Bánya Zóna")}}selected{{/if}}>Bánya Zóna</option>
                <option value="Katonai Zóna" {{#if (eq system.identity.subAssignment "Katonai Zóna")}}selected{{/if}}>Katonai Zóna</option>
                <option value="Kutató Zóna" {{#if (eq system.identity.subAssignment "Kutató Zóna")}}selected{{/if}}>Kutató Zóna</option>
                <option value="Elhagyott Zóna" {{#if (eq system.identity.subAssignment "Elhagyott Zóna")}}selected{{/if}}>Elhagyott Zóna</option>
                <option value="Zónán kívüli terület" {{#if (eq system.identity.subAssignment "Zónán kívüli terület")}}selected{{/if}}>Zónán kívüli terület</option>
              </select>
            </div>
          </div>
          <div class="jarmu-stat-row jarmu-stat-row-duo">
            <div class="jarmu-stat-cell">
              <label>Méret</label>
              <span class="jarmu-header-size-value">{{sizeForSelect}} ({{unitCount}} helyiség)</span>
            </div>
            <div class="jarmu-stat-cell jarmu-stat-cell-threat">
              <label>Veszélyeztetettség</label>
              <input
                type="number"
                name="system.combat.threat"
                class="bazis-threat-total"
                value="{{system.combat.threat}}"
                readonly
              />
              <span class="jarmu-stat-plus">+</span>
              <input
                type="number"
                name="system.combat.threatBonus"
                value="{{system.combat.threatBonus}}"
              />
              <span class="jarmu-stat-unit">%</span>
            </div>
          </div>
        {{else}}
          <div class="jarmu-stat-row">
            <label>Sebesség</label>
            <input
              type="text"
              name="system.combat.speed"
              value="{{system.combat.speed}}"
              placeholder="0"
              data-dtype="String"
              readonly
            />
            <span class="jarmu-stat-unit">TE</span>
          </div>
          <div class="jarmu-stat-row jarmu-stat-row-range">
            <label>Eszközök Hatótávolsága</label>
            <input
              type="text"
              name="system.vehicle.toolsRange"
              value="{{system.vehicle.toolsRange}}"
              placeholder="0"
              data-dtype="String"
              readonly
            />
            <span class="jarmu-stat-unit">TE</span>
          </div>
          <div class="jarmu-stat-row jarmu-stat-row-defense">
            <label>Védelem</label>
            <input type="number" name="system.combat.defense" value="{{system.combat.defense}}" min="0" />
            <span class="jarmu-stat-plus">+</span>
            <input
              type="text"
              class="jarmu-size-defense-effective"
              value="{{sizeDefensePenalty}}"
              readonly
            />
            <span class="jarmu-stat-unit">TE + Távolság</span>
          </div>
        {{/if}}
      </section>
    </section>
  </section>

  <section class="jarmu-section jarmu-units karakter-panel">
    <h2>{{#if (eq actor.type "Bazis")}}Helyiségek és Modulok{{else}}Járműegységek és Modulok{{/if}}</h2>
    <div class="jarmu-units-content{{#unless unitsTable.length}} jarmu-units-content--empty{{/unless}}" data-drop-zone="jarmuegyseg">
      {{#if unitsTable.length}}
        <table class="karakter-equipment-table jarmu-units-table">
          <thead>
            <tr>
              <th class="karakter-equipment-th-name">{{unitItemTypeLabel}}</th>
              {{#if (eq actor.type "Bazis")}}
                <th class="karakter-equipment-th-hit">Cépont szám</th>
                <th class="karakter-equipment-th-level">Szint</th>
              {{else}}
                <th class="karakter-equipment-th-hp">Életerő</th>
                <th class="karakter-equipment-th-hit">Cépont szám</th>
                <th class="karakter-equipment-th-level">Szint</th>
              {{/if}}
              <th class="karakter-equipment-th-delete"></th>
            </tr>
          </thead>
          <tbody>
            {{#each unitsTable}}
              <tr class="karakter-equipment-row jarmu-unit-row {{#if this.isHelyiseg}}jarmu-unit-row-helyiseg{{/if}}"
                  data-item-id="{{this.itemId}}"
                  draggable="true"
                  {{#unless this.isHelyiseg}}data-hp-status="{{this.hpStatus}}"{{/unless}}>
                <td class="karakter-equipment-cell-name">
                  {{#if this.img}}<img class="karakter-equipment-icon jarmu-inventory-item-icon karakter-inventory-item-icon" src="{{this.img}}" alt="" data-item-id="{{this.itemId}}" />{{/if}}
                  <span class="karakter-inventory-item-name jarmu-inventory-item-name" data-item-id="{{this.itemId}}">{{this.name}}</span>
                  {{#unless this.isHelyiseg}}
                    {{#if this.damage}}
                      <button
                        type="button"
                        class="jarmu-unit-damage-button"
                        data-item-id="{{this.itemId}}"
                      >
                        Sebzés ({{this.damage}})
                      </button>
                    {{/if}}
                  {{/unless}}
                </td>
                {{#if this.isHelyiseg}}
                  <td class="karakter-equipment-cell-hit">
                    <input
                      type="text"
                      class="jarmu-unit-hit-input"
                      data-item-id="{{this.itemId}}"
                      value="{{this.hit}}"
                      placeholder="pl. 1–3"
                    />
                  </td>
                  <td class="karakter-equipment-cell-level">{{this.level}}</td>
                {{else}}
                  <td class="karakter-equipment-cell-hp">
                    <span class="jarmu-unit-hp-max">{{this.hpMax}}</span>
                    <span>/</span>
                    <input
                      type="number"
                      class="jarmu-unit-hp-current"
                      data-item-id="{{this.itemId}}"
                      value="{{this.hpValue}}"
                      min="0"
                    />
                  </td>
                  <td class="karakter-equipment-cell-hit">
                    <input
                      type="text"
                      class="jarmu-unit-hit-input"
                      data-item-id="{{this.itemId}}"
                      value="{{this.hit}}"
                      placeholder="pl. 1–3"
                    />
                  </td>
                  <td class="karakter-equipment-cell-level">
                    {{this.level}}
                  </td>
                {{/if}}
                <td class="karakter-equipment-cell-delete">
                  <button
                    type="button"
                    class="karakter-equipment-delete jarmu-item-delete"
                    data-item-id="{{this.itemId}}"
                    data-actor-id="{{this.actorId}}"
                    title="Törlés: Alt + Kattintás"
                  >✕</button>
                </td>
              </tr>
              {{#if this.abilities.length}}
                <tr class="jarmu-unit-abilities-row" data-item-id="{{this.itemId}}">
                  <td class="jarmu-unit-abilities-cell" colspan="{{../unitAbilitiesColspan}}">
                    <div class="jarmu-unit-abilities-list">
                      {{#each this.abilities}}
                        <div class="jarmu-unit-ability-pill jarmu-unit-ability-line" data-ability-ref="{{this.ref}}" data-ability-id="{{this.id}}">
                          <span class="jarmu-unit-ability-name">
                            <span class="jarmu-unit-ability-marker" aria-hidden="true">↳</span>
                            {{#if (eq this.kind "module")}}<strong>Modul:</strong> {{/if}}
                            {{#if (eq this.kind "module")}}
                              <strong>{{this.name}}</strong>
                            {{else}}
                              {{this.name}}
                            {{/if}}
                            {{#if this.kpDisplay}}
                              <span class="jarmu-unit-ability-kp">({{this.kpDisplay}} KP)</span>
                            {{/if}}
                          </span>
                          <button type="button" class="jarmu-unit-ability-chat" title="Beküldés">
                            <i class="fas fa-comment-dots"></i>
                          </button>
                        </div>
                      {{/each}}
                    </div>
                  </td>
                </tr>
              {{/if}}
            {{/each}}
          </tbody>
        </table>
      {{else}}
        <p class="karakter-equipment-placeholder">
          {{#if (eq actor.type "Bazis")}}Húzz ide helyiségeket{{else}}Húzz ide járműegységeket{{/if}}
        </p>
      {{/if}}
    </div>
  </section>

  <section class="jarmu-section jarmu-raktar karakter-panel karakter-equipment{{#if showEquipmentDropZone}} jarmu-raktar--empty{{/if}}">
    <h2>Raktár</h2>
    <div class="jarmu-storage-header">
      <span class="jarmu-storage-label">Raktárkapacitás:</span>
      <span class="jarmu-storage-values">
        <input
          type="number"
          class="jarmu-storage-used"
          value="{{totalStorageUsed}}"
          readonly
        />
        <span class="jarmu-storage-slash">/</span>
        <input
          type="number"
          name="system.vehicle.storage"
          class="jarmu-storage-max"
          value="{{vehicleStorageMax}}"
          min="0"
        />
      </span>
    </div>
    {{#if showEquipmentDropZone}}
    <div class="npc-equipment-drop-zone karakter-equipment-drop-zone" data-drop-zone="targy">
      <p class="npc-equipment-drop-placeholder karakter-equipment-placeholder">Húzz ide bármilyen felszerelést</p>
    </div>
    {{/if}}

    {{#if weaponsTable.length}}
      <h3 class="karakter-equipment-table-title">Fegyverek</h3>
      <div class="karakter-equipment-block">
        <table class="karakter-equipment-table karakter-equipment-weapons">
          <thead>
            <tr>
              <th class="karakter-equipment-th-name">Név</th>
              <th class="karakter-equipment-th-bonus">Bónusz</th>
              <th class="karakter-equipment-th-damage">Sebzés</th>
              <th class="karakter-equipment-th-range">Hatótáv</th>
              <th class="karakter-equipment-th-other">Speciális</th>
              <th class="karakter-equipment-th-delete"></th>
            </tr>
          </thead>
          <tbody>
            {{#each weaponsTable}}
              <tr class="karakter-equipment-row" data-slot-key="{{this.slotKey}}" data-item-id="{{this.itemId}}">
                <td class="karakter-equipment-cell-name">
                  {{#if this.img}}<img class="karakter-equipment-icon jarmu-inventory-item-icon karakter-inventory-item-icon" src="{{this.img}}" alt="" data-item-id="{{this.itemId}}" />{{/if}}
                  <span class="karakter-weapon-label karakter-inventory-item-name jarmu-inventory-item-name" data-weapon-slot="{{this.slotKey}}" data-item-id="{{this.itemId}}">{{this.name}}</span>
                </td>
                <td class="karakter-equipment-cell-bonus">{{this.bonus}}</td>
                <td class="karakter-equipment-cell-damage">{{this.damage}}</td>
                <td class="karakter-equipment-cell-range">{{this.rangeStr}}</td>
                <td class="karakter-equipment-cell-other">{{this.special}}</td>
                <td class="karakter-equipment-cell-delete">
                  <button
                    type="button"
                    class="karakter-equipment-delete karakter-weapon-delete jarmu-item-delete"
                    data-item-id="{{this.itemId}}"
                    data-slot-key="{{this.slotKey}}"
                    data-actor-id="{{this.actorId}}"
                    title="Törlés: Alt + Kattintás"
                  >✕</button>
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    {{/if}}

    {{#if armorTable.length}}
      <h3 class="karakter-equipment-table-title">Páncélok</h3>
      <div class="karakter-equipment-block">
        <table class="karakter-equipment-table karakter-equipment-armor">
          <thead>
            <tr>
              <th class="karakter-equipment-th-name">Név</th>
              <th class="karakter-equipment-th-protection">Védelem Bónusz</th>
              <th class="karakter-equipment-th-speed">Sebesség Levonás (m)</th>
              <th class="karakter-equipment-th-level">Szint</th>
              <th class="karakter-equipment-th-other">Speciális</th>
              <th class="karakter-equipment-th-delete"></th>
            </tr>
          </thead>
          <tbody>
            {{#each armorTable}}
              <tr class="karakter-equipment-row" data-item-id="{{this.itemId}}">
                <td class="karakter-equipment-cell-name">
                  {{#if this.img}}<img class="karakter-equipment-icon jarmu-inventory-item-icon karakter-inventory-item-icon" src="{{this.img}}" alt="" data-item-id="{{this.itemId}}" />{{/if}}
                  <span class="karakter-armor-label karakter-inventory-item-name jarmu-inventory-item-name" data-item-id="{{this.itemId}}">{{this.name}}</span>
                </td>
                <td class="karakter-equipment-cell-bonus">{{this.protectionBonus}}</td>
                <td class="karakter-equipment-cell-speed">{{this.speedPenalty}}</td>
                <td class="karakter-equipment-cell-level">{{this.level}}</td>
                <td class="karakter-equipment-cell-other">{{this.special}}</td>
                <td class="karakter-equipment-cell-delete">
                  <button
                    type="button"
                    class="karakter-equipment-delete karakter-armor-delete jarmu-item-delete"
                    data-item-id="{{this.itemId}}"
                    data-actor-id="{{this.actorId}}"
                    title="Törlés: Alt + Kattintás"
                  >✕</button>
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    {{/if}}

    {{#if microchipsTable.length}}
      <h3 class="karakter-equipment-table-title">Mikro-Chip-ek</h3>
      <div class="karakter-equipment-block">
        <table class="karakter-equipment-table karakter-equipment-microchips">
          <thead>
            <tr>
              <th class="karakter-equipment-th-name">Név</th>
              <th class="karakter-equipment-th-type">Típus</th>
              <th class="karakter-equipment-th-kp">KP</th>
              <th class="karakter-equipment-th-desc">Leírás</th>
              <th class="karakter-equipment-th-delete"></th>
            </tr>
          </thead>
          <tbody>
            {{#each microchipsTable}}
              <tr class="karakter-equipment-row" data-slot-key="{{this.slotKey}}" data-item-id="{{this.itemId}}">
                <td class="karakter-equipment-cell-name">
                  {{#if this.img}}<img class="karakter-equipment-icon jarmu-inventory-item-icon karakter-inventory-item-icon" src="{{this.img}}" alt="" data-item-id="{{this.itemId}}" />{{/if}}
                  <span class="karakter-microchip-label karakter-inventory-item-name jarmu-inventory-item-name" data-item-id="{{this.itemId}}">{{this.name}}</span>
                </td>
                <td class="karakter-equipment-cell-type">{{this.typeLabel}}</td>
                <td class="karakter-equipment-cell-kp">{{#if this.isActive}}{{this.kp}}{{else}}—{{/if}}</td>
                <td class="karakter-equipment-cell-desc">{{this.description}}</td>
                <td class="karakter-equipment-cell-delete">
                  <button
                    type="button"
                    class="karakter-equipment-delete karakter-microchip-delete jarmu-item-delete"
                    data-item-id="{{this.itemId}}"
                    data-slot-key="{{this.slotKey}}"
                    data-actor-id="{{this.actorId}}"
                    title="Törlés: Alt + Kattintás"
                  >✕</button>
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    {{/if}}

    {{#if itemsTable.length}}
      <h3 class="karakter-equipment-table-title">Egyéb Felszerelés</h3>
      <div class="karakter-equipment-block" data-drop-zone="targy">
        <table class="karakter-equipment-table karakter-equipment-items">
          <thead>
            <tr>
              <th class="karakter-equipment-th-name">Név</th>
              <th class="karakter-equipment-th-qty">Mennyiség</th>
              <th class="karakter-equipment-th-desc">Leírás</th>
              <th class="karakter-equipment-th-delete"></th>
            </tr>
          </thead>
          <tbody>
            {{#each itemsTable}}
              <tr class="karakter-equipment-row {{#if this.isPackageChild}}karakter-package-child-row{{/if}}" data-item-id="{{this.itemId}}">
                <td class="karakter-equipment-cell-name">
                  {{#if this.isPackageChild}}
                    <span class="karakter-package-child-marker">↳</span>
                    <span class="karakter-inventory-item-name jarmu-inventory-item-name" data-item-id="{{this.itemId}}">{{this.name}}</span>
                  {{else}}
                    {{#if this.img}}<img class="karakter-equipment-icon jarmu-inventory-item-icon karakter-inventory-item-icon" src="{{this.img}}" alt="" data-item-id="{{this.itemId}}" />{{/if}}
                    <span class="karakter-inventory-item-name jarmu-inventory-item-name" data-item-id="{{this.itemId}}">{{this.name}}</span>
                  {{/if}}
                </td>
                <td class="karakter-equipment-cell-qty">
                  {{#if this.isPackage}}
                    —
                  {{else}}
                    <input type="text" class="karakter-item-quantity-input jarmu-item-quantity-input" data-item-id="{{this.itemId}}" value="{{this.quantity}}" />
                  {{/if}}
                </td>
                <td class="karakter-equipment-cell-desc">{{this.description}}</td>
                <td class="karakter-equipment-cell-delete">
                  {{#unless this.isPackageChild}}
                    <button
                      type="button"
                      class="karakter-equipment-delete karakter-item-delete jarmu-item-delete"
                      data-item-id="{{this.itemId}}"
                      data-actor-id="{{this.actorId}}"
                      title="Törlés: Alt + Kattintás"
                    >✕</button>
                  {{/unless}}
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    {{/if}}
  </section>

  <section class="jarmu-section jarmu-egyeb karakter-panel karakter-notes">
    <h2>Egyéb Információk</h2>
    <div class="karakter-notes-split">
      <div class="karakter-notes-right" data-drop-zone="egyeb">
        <div class="karakter-notes-egyeb-list">
          {{#each egyebList}}
            <div class="karakter-notes-egyeb-row" data-item-id="{{this.itemId}}">
              {{#if this.img}}<img class="karakter-notes-egyeb-icon jarmu-egyeb-icon" src="{{this.img}}" alt="" data-item-id="{{this.itemId}}" />{{/if}}
              <div class="karakter-notes-egyeb-main">
                <span class="karakter-notes-egyeb-name jarmu-egyeb-name" data-item-id="{{this.itemId}}">{{this.name}}</span>
                {{#if this.description}}<p class="karakter-notes-egyeb-desc">{{this.description}}</p>{{/if}}
              </div>
              <button type="button" class="karakter-item-chat" data-item-id="{{this.itemId}}" title="Beküldés"><i class="fas fa-comment-dots"></i></button>
              <button type="button" class="karakter-equipment-delete jarmu-egyeb-delete" data-item-id="{{this.itemId}}" data-actor-id="{{this.actorId}}" title="Törlés: Alt + Kattintás">✕</button>
            </div>
          {{else}}
            <p class="karakter-notes-egyeb-placeholder">Húzz ide egyéb információt</p>
          {{/each}}
        </div>
      </div>
      <div class="karakter-notes-left">
        <textarea name="system.notes.biography" data-dtype="String" rows="3" placeholder="Írj ide egyéb információkat...">{{system.notes.biography}}</textarea>
      </div>
    </div>
  </section>
</form>
