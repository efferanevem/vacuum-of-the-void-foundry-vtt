<form class="{{cssClass}} votv-egyeb-sheet" autocomplete="off">
  <header class="sheet-header">
    <div class="header-fields">
      <h1 class="item-name">
        <input name="name" type="text" value="{{item.name}}" placeholder="Egyéb információ neve" />
      </h1>
    </div>
  </header>

  <section class="sheet-body">
    <div class="field">
      <label>Leírás</label>
      <textarea name="system.description" rows="{{descriptionRows}}">{{system.description}}</textarea>
    </div>
  </section>
</form>
